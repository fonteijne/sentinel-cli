# ---------------------------------------------------------------------------
# Sentinel Command Center — environment file template.
#
# Copy to `.env` next to docker-compose.yml and fill in the values below.
# `docker compose` auto-loads `.env`, so no --env-file flag is required.
# `.env` is gitignored; `.env.example` is the committed template.
# ---------------------------------------------------------------------------

# Required for `docker compose --profile serve up`.
# Hostname the prod backend is reachable on; must have a DNS A/AAAA record
# pointing to the Docker host BEFORE first compose up (Let's Encrypt HTTP-01
# needs the name to resolve before it can issue a cert).
SENTINEL_HOSTNAME=sentinel.iobonzai.com

# Required for `docker compose --profile traefik up` (Let's Encrypt
# registration email). One-time use: Let's Encrypt emails this address for
# expiry warnings and policy changes. Use a shared/alias inbox so it survives
# team changes. Matches the git identity already configured in the Dockerfile
# so the stack is consistent end-to-end.
LETSENCRYPT_EMAIL=sentinel.utrecht@iodigital.com

# `/docs` exposure is NOT controlled here — the setting is hardcoded
# per-service in docker-compose.yml (dev: on, prod: off). To temporarily
# expose /docs + /redoc + /openapi.json on the prod sentinel-serve
# service, drop a `docker-compose.override.yml` (gitignored) beside this
# file with:
#
#   services:
#     sentinel-serve:
#       environment:
#         - SENTINEL_ENABLE_DOCS=true
#
# Then `docker compose --profile serve up -d sentinel-serve`. Delete the
# override file to flip prod /docs back off. See docs/deploy.md §7.

# Optional — override the on-disk service token (~/.sentinel/service_token
# inside the container). Leave unset to let the service auto-generate one on
# first boot. Rotating = delete the file and restart sentinel-serve.
# SENTINEL_SERVICE_TOKEN=

# Reserved for future plan 07 (dashboard UI) — profile-gated container under
# `--profile dashboard`. Not read by any service today; pre-documented so
# operators keep hostname conventions consistent with SENTINEL_HOSTNAME.
# Uncomment and set when plan 07 lands.
# SENTINEL_DASHBOARD_HOSTNAME=dashboard.iobonzai.com
