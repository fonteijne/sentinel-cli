# Jira API Configuration
JIRA_API_TOKEN=your_jira_token_here
JIRA_EMAIL=your_email@company.com
JIRA_BASE_URL=https://your-company.atlassian.net

# GitLab API Configuration
GITLAB_API_TOKEN=your_gitlab_token_here
GITLAB_BASE_URL=https://gitlab.com

# LLM Configuration
#
# Mode is auto-detected based on which variables are set:
#   - ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL = Custom proxy
#   - ANTHROPIC_API_KEY only = Direct Anthropic API
#   - Neither = Claude Code subscription (requires auth)
#
# For custom proxy (e.g., LLM Provider):
# ANTHROPIC_API_KEY=your_proxy_api_key
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1
#
# For direct Anthropic API:
# ANTHROPIC_API_KEY=sk-ant-your_key_here
#
# For Claude Code subscription (comment out both):
# (No env vars needed - uses Claude Code authentication)

# Workspace Configuration
WORKSPACE_ROOT=~/sentinel-workspaces
